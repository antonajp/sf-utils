# Salesforce OAuth credentials
SF_USERNAME=your-username@example.com
SF_PASSWORD=your-password
SF_CLIENT_ID=your-connected-app-client-id
SF_CLIENT_SECRET=your-connected-app-client-secret

# Optional: Use sandbox instead of production
SF_SANDBOX=false

# Optional: API version (defaults to latest)
SF_API_VERSION=v61.0

# PostgreSQL connection (Docker container)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=sf_utils
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# Optional: SSL mode (prefer, require, disable)
PG_SSLMODE=prefer

# Optional: Connection pool settings (not yet implemented)
PG_MIN_CONNECTIONS=1
PG_MAX_CONNECTIONS=10
