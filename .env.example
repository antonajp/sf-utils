# =============================================================================
# Salesforce Authentication
# =============================================================================
# Two authentication flows are supported:
#   1. JWT Bearer Flow (recommended for MFA-enabled orgs, CI/CD, automation)
#   2. Password Flow (legacy, requires security token, no MFA)
#
# The client auto-detects which flow to use based on SF_PRIVATE_KEY_PATH:
#   - If SF_PRIVATE_KEY_PATH is set → JWT Bearer Flow
#   - Otherwise → Password Flow

# -----------------------------------------------------------------------------
# Common Settings (both flows)
# -----------------------------------------------------------------------------
SF_USERNAME=your-username@example.com
SF_CLIENT_ID=your-connected-app-consumer-key
SF_SANDBOX=false                    # true for sandbox orgs (test.salesforce.com)
SF_API_VERSION=v61.0                # optional, defaults to latest

# -----------------------------------------------------------------------------
# JWT Bearer Flow (recommended)
# -----------------------------------------------------------------------------
# Requires a Connected App with:
#   - "Enable OAuth Settings" checked
#   - "Use digital signatures" enabled with your X.509 certificate uploaded
#   - OAuth scopes: api, refresh_token (minimum)
#   - Pre-authorized users or admin approval
#
# See README.md for complete setup instructions.

SF_PRIVATE_KEY_PATH=/path/to/server.key     # Path to your private key file
SF_PRIVATE_KEY_PASSPHRASE=                  # Optional: passphrase if key is encrypted

# -----------------------------------------------------------------------------
# Password Flow (legacy)
# -----------------------------------------------------------------------------
# Only use if JWT Bearer is not possible. Requires:
#   - Security token appended to password (or IP whitelisting)
#   - MFA disabled or bypassed for API access
#
# Uncomment and set these (and remove/comment JWT settings above):

# SF_PASSWORD=your-password-plus-security-token
# SF_CLIENT_SECRET=your-connected-app-consumer-secret

# =============================================================================
# PostgreSQL (Docker container)
# =============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=sf_utils
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# Optional: SSL mode (prefer, require, disable)
PG_SSLMODE=prefer

# Optional: Connection pool settings (not yet implemented)
PG_MIN_CONNECTIONS=1
PG_MAX_CONNECTIONS=10
